<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>

        <!-- Dark theme (default) -->
        <ResourceDictionary x:Key="Dark">
            <x:Double x:Key="ProgressBarThemeMinHeight">6</x:Double>
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#1C1C1E" />
            <SolidColorBrush x:Key="SectionHeaderBrush" Color="#8E8E93" />
            <SolidColorBrush x:Key="DividerBrush" Color="#3A3A3A" />
            <SolidColorBrush x:Key="ProgressTrackBrush" Color="#72808080" />
            <SolidColorBrush x:Key="PrimaryTextBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="SecondaryTextBrush" Color="#8E8E93" />
            <SolidColorBrush x:Key="TertiaryTextBrush" Color="#636366" />
            <SolidColorBrush x:Key="ProgressGreenBrush" Color="#30D158" />
            <SolidColorBrush x:Key="ProgressYellowBrush" Color="#FFD60A" />
            <SolidColorBrush x:Key="ProgressOrangeBrush" Color="#FF9F0A" />
            <SolidColorBrush x:Key="ProgressRedBrush" Color="#FF453A" />
            <SolidColorBrush x:Key="FooterHoverBrush" Color="#3A3A3A" />
            <SolidColorBrush x:Key="ChartBackgroundBrush" Color="#2C2C2E" />
            <SolidColorBrush x:Key="SegmentedBackgroundBrush" Color="#38383A" />
            <SolidColorBrush x:Key="SegmentedActiveBackgroundBrush" Color="#636366" />
            <SolidColorBrush x:Key="ShimmerBaseBrush" Color="#38383A" />
            <SolidColorBrush x:Key="ShimmerHighlightBrush" Color="#555558" />
            <SolidColorBrush x:Key="BurnRateWarningBrush" Color="#FF453A" />
        </ResourceDictionary>

        <!-- Light theme -->
        <ResourceDictionary x:Key="Light">
            <x:Double x:Key="ProgressBarThemeMinHeight">6</x:Double>
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F5F5F5" />
            <SolidColorBrush x:Key="SectionHeaderBrush" Color="#6E6E73" />
            <SolidColorBrush x:Key="DividerBrush" Color="#D0D0D0" />
            <SolidColorBrush x:Key="ProgressTrackBrush" Color="#72808080" />
            <SolidColorBrush x:Key="PrimaryTextBrush" Color="#1C1C1E" />
            <SolidColorBrush x:Key="SecondaryTextBrush" Color="#6E6E73" />
            <SolidColorBrush x:Key="TertiaryTextBrush" Color="#8E8E93" />
            <SolidColorBrush x:Key="ProgressGreenBrush" Color="#34C759" />
            <SolidColorBrush x:Key="ProgressYellowBrush" Color="#FFCC00" />
            <SolidColorBrush x:Key="ProgressOrangeBrush" Color="#FF9500" />
            <SolidColorBrush x:Key="ProgressRedBrush" Color="#FF3B30" />
            <SolidColorBrush x:Key="FooterHoverBrush" Color="#E8E8ED" />
            <SolidColorBrush x:Key="ChartBackgroundBrush" Color="#EBEBF0" />
            <SolidColorBrush x:Key="SegmentedBackgroundBrush" Color="#E5E5EA" />
            <SolidColorBrush x:Key="SegmentedActiveBackgroundBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="ShimmerBaseBrush" Color="#E5E5EA" />
            <SolidColorBrush x:Key="ShimmerHighlightBrush" Color="#D1D1D6" />
            <SolidColorBrush x:Key="BurnRateWarningBrush" Color="#FF3B30" />
        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>

    <!-- Override WinUI 3 ProgressBar track/indicator dimensions globally.
         ProgressBarTrackHeight defaults to 1px — override to 6px so track matches indicator. -->
    <x:Double x:Key="ProgressBarTrackHeight">6</x:Double>
    <CornerRadius x:Key="ProgressBarTrackCornerRadius">3</CornerRadius>

    <!-- ProgressBar style: Height=6 for the control bounding box, CornerRadius for indicator. -->
    <Style x:Key="AppProgressBarStyle" TargetType="ProgressBar">
        <Setter Property="Height" Value="6" />
        <Setter Property="MinHeight" Value="6" />
        <Setter Property="CornerRadius" Value="3" />
    </Style>

</ResourceDictionary>
