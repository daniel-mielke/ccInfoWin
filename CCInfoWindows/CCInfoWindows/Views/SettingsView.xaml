<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CCInfoWindows.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:l="using:WinUI3Localizer"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource AppBackgroundBrush}" Padding="16,12"
          RowDefinitions="Auto,*,Auto">

        <!-- Header row with back button and title -->
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,16">
            <Button l:Uids.Uid="SettingsBackButton"
                    Command="{x:Bind ViewModel.GoBackCommand}"
                    Background="Transparent" BorderThickness="0" Padding="4">
                <FontIcon Glyph="&#xE72B;" FontSize="16"
                          Foreground="{ThemeResource PrimaryTextBrush}" />
            </Button>
            <TextBlock l:Uids.Uid="SettingsHeader"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{ThemeResource SectionHeaderBrush}"
                       VerticalAlignment="Center" CharacterSpacing="50" />
        </StackPanel>

        <!-- Settings content -->
        <StackPanel Grid.Row="1" Spacing="24">
            <!-- Refresh interval -->
            <StackPanel Spacing="8">
                <TextBlock l:Uids.Uid="SettingsRefreshInterval"
                           FontSize="13" Foreground="{ThemeResource PrimaryTextBrush}" />
                <ComboBox l:Uids.Uid="RefreshIntervalComboBox"
                          ItemsSource="{x:Bind ViewModel.RefreshOptions}"
                          SelectedItem="{x:Bind ViewModel.SelectedRefreshOption, Mode=TwoWay}"
                          DisplayMemberPath="Label"
                          HorizontalAlignment="Stretch" />
            </StackPanel>

            <!-- Divider -->
            <Border Height="1" Background="{ThemeResource DividerBrush}" />

            <!-- Session activity timeout -->
            <StackPanel Spacing="8">
                <TextBlock l:Uids.Uid="SettingsSessionTimeout"
                           FontSize="13" Foreground="{ThemeResource PrimaryTextBrush}" />
                <ComboBox l:Uids.Uid="SessionTimeoutComboBox"
                          SelectedIndex="{x:Bind ViewModel.SelectedThresholdIndex, Mode=TwoWay}"
                          HorizontalAlignment="Stretch">
                    <ComboBoxItem l:Uids.Uid="Timeout15" />
                    <ComboBoxItem l:Uids.Uid="Timeout30" />
                    <ComboBoxItem l:Uids.Uid="Timeout60" />
                    <ComboBoxItem l:Uids.Uid="Timeout120" />
                </ComboBox>
            </StackPanel>

            <!-- Divider -->
            <Border Height="1" Background="{ThemeResource DividerBrush}" />

            <!-- Dark/Light mode -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock l:Uids.Uid="SettingsDarkMode"
                           FontSize="13" Foreground="{ThemeResource PrimaryTextBrush}"
                           VerticalAlignment="Center" />
                <ToggleSwitch Grid.Column="1"
                              l:Uids.Uid="DarkModeToggle"
                              IsOn="{x:Bind ViewModel.IsDarkMode, Mode=TwoWay}"
                              OnContent="" OffContent="" />
            </Grid>
            <!-- Divider before Pricing Info -->
            <Border Height="1" Background="{ThemeResource DividerBrush}" />

            <!-- Pricing Info (COST-06) -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock l:Uids.Uid="SettingsPricingSource" Grid.Row="0" Grid.Column="0" FontSize="13"
                           Foreground="{ThemeResource SecondaryTextBrush}" Margin="0,0,12,0" />
                <TextBlock Grid.Row="0" Grid.Column="1"
                           Text="{x:Bind ViewModel.PricingSourceText}"
                           FontSize="13" HorizontalAlignment="Right"
                           Foreground="{ThemeResource PrimaryTextBrush}" />
                <TextBlock l:Uids.Uid="SettingsLastFetch" Grid.Row="1" Grid.Column="0" FontSize="13"
                           Foreground="{ThemeResource SecondaryTextBrush}" Margin="0,4,12,0" />
                <TextBlock Grid.Row="1" Grid.Column="1"
                           Text="{x:Bind ViewModel.LastPricingFetchText}"
                           FontSize="13" HorizontalAlignment="Right"
                           Foreground="{ThemeResource PrimaryTextBrush}" Margin="0,4,0,0" />
            </Grid>

            <!-- Divider before ANWENDUNG -->
            <Border Height="1" Background="{ThemeResource DividerBrush}" />

            <!-- ANWENDUNG section -->
            <StackPanel Spacing="8">
                <TextBlock l:Uids.Uid="SectionHeaderApp"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{ThemeResource SectionHeaderBrush}"
                           CharacterSpacing="50" />

                <!-- Autostart row -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock l:Uids.Uid="SettingsAutostartLabel"
                               FontSize="13" Foreground="{ThemeResource PrimaryTextBrush}"
                               VerticalAlignment="Center" />
                    <ToggleSwitch Grid.Column="1"
                                  l:Uids.Uid="AutostartToggle"
                                  IsOn="{x:Bind ViewModel.IsAutostart, Mode=TwoWay}" />
                </Grid>

                <!-- Language row -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock l:Uids.Uid="SettingsLanguageLabel"
                               FontSize="13" Foreground="{ThemeResource PrimaryTextBrush}"
                               VerticalAlignment="Center" />
                    <ComboBox Grid.Column="1"
                              l:Uids.Uid="LanguageComboBox"
                              Width="120"
                              SelectedIndex="{x:Bind ViewModel.SelectedLanguageIndex, Mode=TwoWay}">
                        <ComboBoxItem Content="Deutsch" />
                        <ComboBoxItem Content="English" />
                    </ComboBox>
                </Grid>
            </StackPanel>
        </StackPanel>

        <!-- Logout button at bottom -->
        <Button l:Uids.Uid="SettingsLogoutButton"
                Grid.Row="2"
                Command="{x:Bind ViewModel.LogoutCommand}"
                HorizontalAlignment="Stretch"
                Margin="0,16,0,0"
                Style="{ThemeResource AccentButtonStyle}" />
    </Grid>
</Page>
