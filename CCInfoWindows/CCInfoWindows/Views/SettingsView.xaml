<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CCInfoWindows.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:l="using:WinUI3Localizer"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource AppBackgroundBrush}" Padding="16,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Row 0: Header — back button + title -->
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,16">
            <Button l:Uids.Uid="SettingsBackButton"
                    Command="{x:Bind ViewModel.GoBackCommand}"
                    Background="Transparent" BorderThickness="0" Padding="4">
                <FontIcon Glyph="&#xE72B;" FontSize="16"
                          Foreground="{ThemeResource PrimaryTextBrush}" />
            </Button>
            <TextBlock l:Uids.Uid="SettingsHeader"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{ThemeResource SectionHeaderBrush}"
                       VerticalAlignment="Center" CharacterSpacing="50" />
        </StackPanel>

        <!-- Row 1: Segmented Control — 4 tabs with colored icon badges -->
        <controls:Segmented Grid.Row="1"
            HorizontalAlignment="Stretch"
            Margin="0,0,0,12"
            SelectedIndex="{x:Bind ViewModel.SelectedTabIndex, Mode=TwoWay}">

            <!-- General tab (green badge) -->
            <controls:SegmentedItem x:Name="TabGeneral">
                <controls:SegmentedItem.Content>
                    <Border Width="30" Height="30" CornerRadius="6"
                            Background="{ThemeResource SettingsBadgeGreenBrush}">
                        <FontIcon Glyph="&#xE713;" FontSize="16" Foreground="White" />
                    </Border>
                </controls:SegmentedItem.Content>
            </controls:SegmentedItem>

            <!-- Updates tab (blue badge) -->
            <controls:SegmentedItem x:Name="TabUpdates">
                <controls:SegmentedItem.Content>
                    <Border Width="30" Height="30" CornerRadius="6"
                            Background="{ThemeResource SettingsBadgeBlueBrush}">
                        <FontIcon Glyph="&#xE895;" FontSize="16" Foreground="White" />
                    </Border>
                </controls:SegmentedItem.Content>
            </controls:SegmentedItem>

            <!-- Account tab (red badge) -->
            <controls:SegmentedItem x:Name="TabAccount">
                <controls:SegmentedItem.Content>
                    <Border Width="30" Height="30" CornerRadius="6"
                            Background="{ThemeResource SettingsBadgeRedBrush}">
                        <FontIcon Glyph="&#xE77B;" FontSize="16" Foreground="White" />
                    </Border>
                </controls:SegmentedItem.Content>
            </controls:SegmentedItem>

            <!-- About tab (orange badge) -->
            <controls:SegmentedItem x:Name="TabAbout">
                <controls:SegmentedItem.Content>
                    <Border Width="30" Height="30" CornerRadius="6"
                            Background="{ThemeResource SettingsBadgeOrangeBrush}">
                        <FontIcon Glyph="&#xE946;" FontSize="16" Foreground="White" />
                    </Border>
                </controls:SegmentedItem.Content>
            </controls:SegmentedItem>

        </controls:Segmented>

        <!-- Row 2: Tab content panels in ScrollViewer -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <Grid>

                <!-- PANEL 1 — General Tab -->
                <StackPanel Spacing="8"
                            Visibility="{x:Bind ViewModel.IsGeneralTabVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">

                    <TextBlock l:Uids.Uid="SettingsGeneralHeader"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{ThemeResource SectionHeaderBrush}"
                               CharacterSpacing="50" Margin="0,0,0,8" />

                    <Border CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <StackPanel>

                            <!-- Row 1: Autostart -->
                            <Grid Height="40" Padding="12,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock l:Uids.Uid="SettingsAutostartLabel"
                                           FontSize="13" Foreground="{ThemeResource PrimaryTextBrush}"
                                           VerticalAlignment="Center" />
                                <ToggleSwitch Grid.Column="1"
                                             l:Uids.Uid="AutostartToggle"
                                             IsOn="{x:Bind ViewModel.IsAutostart, Mode=TwoWay}"
                                             MinWidth="0" OnContent="" OffContent=""
                                             VerticalAlignment="Center" />
                            </Grid>

                            <Border Height="1" Background="{ThemeResource DividerBrush}" Margin="12,4" />

                            <!-- Row 2: Refresh Interval -->
                            <Grid Height="40" Padding="12,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock l:Uids.Uid="SettingsRefreshInterval"
                                           FontSize="13" Foreground="{ThemeResource PrimaryTextBrush}"
                                           VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1"
                                          l:Uids.Uid="RefreshIntervalComboBox"
                                          ItemsSource="{x:Bind ViewModel.RefreshOptions}"
                                          SelectedItem="{x:Bind ViewModel.SelectedRefreshOption, Mode=TwoWay}"
                                          DisplayMemberPath="Label"
                                          VerticalAlignment="Center" />
                            </Grid>

                            <Border Height="1" Background="{ThemeResource DividerBrush}" Margin="12,4" />

                            <!-- Row 3: Session Timeout -->
                            <Grid Height="40" Padding="12,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock l:Uids.Uid="SettingsSessionTimeout"
                                           FontSize="13" Foreground="{ThemeResource PrimaryTextBrush}"
                                           VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1"
                                          l:Uids.Uid="SessionTimeoutComboBox"
                                          SelectedIndex="{x:Bind ViewModel.SelectedThresholdIndex, Mode=TwoWay}"
                                          VerticalAlignment="Center">
                                    <ComboBoxItem Content="15min" />
                                    <ComboBoxItem Content="30min" />
                                    <ComboBoxItem Content="60min" />
                                    <ComboBoxItem Content="120min" />
                                </ComboBox>
                            </Grid>

                            <Border Height="1" Background="{ThemeResource DividerBrush}" Margin="12,4" />

                            <!-- Row 4: Dark Mode -->
                            <Grid Height="40" Padding="12,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock l:Uids.Uid="SettingsDarkMode"
                                           FontSize="13" Foreground="{ThemeResource PrimaryTextBrush}"
                                           VerticalAlignment="Center" />
                                <ToggleSwitch Grid.Column="1"
                                             l:Uids.Uid="DarkModeToggle"
                                             IsOn="{x:Bind ViewModel.IsDarkMode, Mode=TwoWay}"
                                             MinWidth="0" OnContent="" OffContent=""
                                             VerticalAlignment="Center" />
                            </Grid>

                            <Border Height="1" Background="{ThemeResource DividerBrush}" Margin="12,4" />

                            <!-- Row 5: Language -->
                            <Grid Height="40" Padding="12,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock l:Uids.Uid="SettingsLanguageLabel"
                                           FontSize="13" Foreground="{ThemeResource PrimaryTextBrush}"
                                           VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1"
                                          l:Uids.Uid="LanguageComboBox"
                                          Width="120"
                                          SelectedIndex="{x:Bind ViewModel.SelectedLanguageIndex, Mode=TwoWay}"
                                          VerticalAlignment="Center">
                                    <ComboBoxItem Content="Deutsch" />
                                    <ComboBoxItem Content="English" />
                                </ComboBox>
                            </Grid>

                            <Border Height="1" Background="{ThemeResource DividerBrush}" Margin="12,4" />

                            <!-- Row 6: Sonnet Context -->
                            <Grid Height="40" Padding="12,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock l:Uids.Uid="SettingsSonnetContextLabel"
                                           FontSize="13" Foreground="{ThemeResource PrimaryTextBrush}"
                                           VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1"
                                          l:Uids.Uid="SonnetContextComboBox"
                                          Width="120"
                                          SelectedIndex="{x:Bind ViewModel.SelectedSonnetContextIndex, Mode=TwoWay}"
                                          VerticalAlignment="Center">
                                    <ComboBoxItem Content="200K" />
                                    <ComboBoxItem Content="1M" />
                                </ComboBox>
                            </Grid>

                            <Border Height="1" Background="{ThemeResource DividerBrush}" Margin="12,4" />

                            <!-- Row 7: Reset Window Size -->
                            <Grid Height="40" Padding="12,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock l:Uids.Uid="SettingsResetWindowSizeLabel"
                                           FontSize="13" Foreground="{ThemeResource PrimaryTextBrush}"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        l:Uids.Uid="SettingsResetWindowSizeButton"
                                        Command="{x:Bind ViewModel.ResetWindowSizeCommand}"
                                        VerticalAlignment="Center" />
                            </Grid>

                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- PANEL 2 — Updates Tab -->
                <StackPanel Spacing="8"
                            Visibility="{x:Bind ViewModel.IsUpdatesTabVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">

                    <TextBlock l:Uids.Uid="SettingsUpdatesHeader"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{ThemeResource SectionHeaderBrush}"
                               CharacterSpacing="50" Margin="0,0,0,8" />

                    <Border CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <StackPanel>

                            <!-- Row 1: App Version -->
                            <Grid Height="40" Padding="12,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock l:Uids.Uid="SettingsAppVersion"
                                           FontSize="13" Foreground="{ThemeResource PrimaryTextBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind ViewModel.AppVersionText}"
                                           FontSize="13" HorizontalAlignment="Right"
                                           Foreground="{ThemeResource PrimaryTextBrush}"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <Border Height="1" Background="{ThemeResource DividerBrush}" Margin="12,4" />

                            <!-- Row 2: Pricing Source -->
                            <Grid Height="40" Padding="12,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock l:Uids.Uid="SettingsPricingSourceLabel"
                                           FontSize="13" Foreground="{ThemeResource PrimaryTextBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind ViewModel.PricingSourceText}"
                                           FontSize="13" HorizontalAlignment="Right"
                                           Foreground="{ThemeResource PrimaryTextBrush}"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <Border Height="1" Background="{ThemeResource DividerBrush}" Margin="12,4" />

                            <!-- Row 3: Last Pricing Fetch -->
                            <Grid Height="40" Padding="12,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock l:Uids.Uid="SettingsLastFetchLabel"
                                           FontSize="13" Foreground="{ThemeResource PrimaryTextBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind ViewModel.LastPricingFetchText}"
                                           FontSize="13" HorizontalAlignment="Right"
                                           Foreground="{ThemeResource PrimaryTextBrush}"
                                           VerticalAlignment="Center" />
                            </Grid>

                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- PANEL 3 — Account Tab -->
                <StackPanel Spacing="8"
                            Visibility="{x:Bind ViewModel.IsAccountTabVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">

                    <TextBlock l:Uids.Uid="SettingsAccountHeader"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{ThemeResource SectionHeaderBrush}"
                               CharacterSpacing="50" Margin="0,0,0,8" />

                    <Border CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <StackPanel>

                            <!-- Row 1: Token Status -->
                            <Grid Height="40" Padding="12,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock l:Uids.Uid="SettingsTokenStatus"
                                           FontSize="13" Foreground="{ThemeResource PrimaryTextBrush}"
                                           VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock l:Uids.Uid="SettingsTokenValid"
                                               FontSize="13" Foreground="{ThemeResource ProgressGreenBrush}"
                                               Visibility="{x:Bind ViewModel.IsTokenValid, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <TextBlock l:Uids.Uid="SettingsTokenInvalid"
                                               FontSize="13" Foreground="{ThemeResource ProgressRedBrush}"
                                               Visibility="{x:Bind ViewModel.IsTokenValid, Mode=OneWay, Converter={StaticResource InvertedBoolToVisibilityConverter}}" />
                                </StackPanel>
                            </Grid>

                            <Border Height="1" Background="{ThemeResource DividerBrush}" Margin="12,4" />

                            <!-- Row 2: Logout Button -->
                            <Button Command="{x:Bind ViewModel.LogoutCommand}"
                                    HorizontalAlignment="Stretch"
                                    Background="{ThemeResource ProgressRedBrush}"
                                    Foreground="White"
                                    Margin="12,8,12,8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xF3B1;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="White" />
                                    <TextBlock l:Uids.Uid="SettingsLogoutButton" Foreground="White" />
                                </StackPanel>
                            </Button>

                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- PANEL 4 — About Tab -->
                <StackPanel Spacing="8"
                            Visibility="{x:Bind ViewModel.IsAboutTabVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">

                    <TextBlock l:Uids.Uid="SettingsAboutHeader"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{ThemeResource SectionHeaderBrush}"
                               CharacterSpacing="50" Margin="0,0,0,8" />

                    <Border CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <StackPanel>

                            <!-- Row 1: App Name -->
                            <Grid Height="40" Padding="12,0">
                                <TextBlock l:Uids.Uid="SettingsAboutAppName"
                                           FontSize="15" FontWeight="SemiBold"
                                           Foreground="{ThemeResource PrimaryTextBrush}"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <Border Height="1" Background="{ThemeResource DividerBrush}" Margin="12,4" />

                            <!-- Row 2: Version -->
                            <Grid Height="40" Padding="12,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock l:Uids.Uid="SettingsVersion"
                                           FontSize="13" Foreground="{ThemeResource PrimaryTextBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind ViewModel.AppVersionText}"
                                           FontSize="13" HorizontalAlignment="Right"
                                           Foreground="{ThemeResource PrimaryTextBrush}"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <Border Height="1" Background="{ThemeResource DividerBrush}" Margin="12,4" />

                            <!-- Row 3: GitHub Link -->
                            <Grid Height="40" Padding="12,0">
                                <HyperlinkButton NavigateUri="https://github.com/stefanlange/ccInfo"
                                                 HorizontalAlignment="Left"
                                                 VerticalAlignment="Center"
                                                 Padding="0">
                                    <TextBlock l:Uids.Uid="SettingsAboutGitHubLink" FontSize="13" />
                                </HyperlinkButton>
                            </Grid>

                            <Border Height="1" Background="{ThemeResource DividerBrush}" Margin="12,4" />

                            <!-- Row 4: Credits -->
                            <Grid MinHeight="40" Padding="12,8">
                                <TextBlock l:Uids.Uid="SettingsAboutCredits"
                                           FontSize="12" Foreground="{ThemeResource SecondaryTextBrush}"
                                           TextWrapping="Wrap" VerticalAlignment="Center" />
                            </Grid>

                        </StackPanel>
                    </Border>
                </StackPanel>

            </Grid>
        </ScrollViewer>

    </Grid>
</Page>
