<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CCInfoWindows.Views.MainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    xmlns:viewmodels="using:CCInfoWindows.ViewModels"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:local="using:CCInfoWindows.Views"
    xmlns:l="using:WinUI3Localizer"
    mc:Ignorable="d"
    Padding="0">

    <Page.Resources>
        <!-- Spinner rotation storyboard -->
        <Storyboard x:Name="SpinnerStoryboard">
            <DoubleAnimation
                Storyboard.TargetName="RefreshIconTransform"
                Storyboard.TargetProperty="Angle"
                From="0" To="360"
                Duration="0:0:1" />
        </Storyboard>

        <!-- Session list for ComboBox (flat, sorted by activity) -->
    </Page.Resources>

    <Grid Background="{ThemeResource AppBackgroundBrush}"
          RowDefinitions="Auto,*">

        <!-- Hidden WebView2 for API calls via Chromium fetch() — bypasses Cloudflare -->
        <WebView2
            x:Name="ApiBridgeWebView"
            Visibility="Collapsed"
            Width="0" Height="0" />

        <!-- Row 0: InfoBars (update + session expired) -->
        <StackPanel Grid.Row="0">
            <!-- Update available InfoBar -->
            <InfoBar
                l:Uids.Uid="UpdateInfoBar"
                Severity="Informational"
                IsOpen="{x:Bind ViewModel.IsUpdateAvailable, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.IsUpdateAvailable, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                Message="{x:Bind ViewModel.UpdateMessage, Mode=OneWay}"
                IsClosable="True"
                Closing="OnUpdateInfoBarClosing"
                Margin="0,0,0,4">
                <InfoBar.ActionButton>
                    <Button l:Uids.Uid="UpdateDownloadButton"
                            Command="{x:Bind ViewModel.OpenUpdateDownloadCommand}" />
                </InfoBar.ActionButton>
            </InfoBar>

            <!-- Session expired InfoBar -->
            <InfoBar
                l:Uids.Uid="SessionExpiredInfoBar"
                Severity="Warning"
                IsOpen="{x:Bind ViewModel.IsSessionExpired, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.IsSessionExpired, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                IsClosable="False"
                Margin="0,0,0,12">
                <InfoBar.ActionButton>
                    <Button Command="{x:Bind ViewModel.ReLoginCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE77B;" FontSize="16" />
                            <TextBlock l:Uids.Uid="ReLoginButton" />
                        </StackPanel>
                    </Button>
                </InfoBar.ActionButton>
            </InfoBar>

            <!-- API error InfoBar -->
            <InfoBar
                Severity="Error"
                Title="API Error"
                Message="{x:Bind ViewModel.ApiErrorMessage, Mode=OneWay}"
                IsOpen="{x:Bind ViewModel.HasApiError, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.HasApiError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                IsClosable="True"
                Margin="0,0,0,12" />
        </StackPanel>

        <!-- Row 1: Dashboard content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12" Padding="16,12,16,12">

                <!-- ==================== AKTIVE SITZUNG ==================== -->
                <TextBlock l:Uids.Uid="SectionHeaderActiveSession"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{ThemeResource SectionHeaderBrush}"
                           CharacterSpacing="50" />

                <!-- ==================== SESSION DROPDOWN ==================== -->
                <ComboBox x:Name="SessionComboBox"
                          l:Uids.Uid="SessionComboBox"
                          ItemsSource="{x:Bind ViewModel.SortedSessions, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedSession, Mode=TwoWay}"
                          HorizontalAlignment="Stretch"
                          Background="{ThemeResource SegmentedBackgroundBrush}"
                          CornerRadius="8">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="viewmodels:SessionDisplayItem">
                            <TextBlock Text="{x:Bind DisplayName}"
                                       VerticalAlignment="Center" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Scanning indicator -->
                <TextBlock l:Uids.Uid="ScanningIndicator"
                           FontSize="12"
                           Foreground="{ThemeResource SecondaryTextBrush}"
                           HorizontalAlignment="Center"
                           Visibility="{x:Bind ViewModel.IsJsonlScanning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                <!-- "Aktualisiere..." indicator on startup -->
                <TextBlock
                    l:Uids.Uid="UpdatingIndicator"
                    FontSize="12"
                    Foreground="{ThemeResource SecondaryTextBrush}"
                    HorizontalAlignment="Center"
                    Visibility="{x:Bind ViewModel.IsUpdatingFromCache, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                <!-- Divider below Active Session dropdown -->
                <Border Height="1" Background="{ThemeResource DividerBrush}" />

                <!-- ==================== KONTEXTFENSTER ==================== -->
                <StackPanel Spacing="8">
                    <TextBlock l:Uids.Uid="SectionHeaderContextWindow"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{ThemeResource SectionHeaderBrush}"
                               CharacterSpacing="50" />

                    <!-- Main context progress bar -->
                    <ProgressBar Value="{x:Bind ViewModel.ContextPercentage, Mode=OneWay}"
                                 Maximum="100"
                                 Foreground="{x:Bind ViewModel.ContextUtilization, Mode=OneWay, Converter={StaticResource PercentageToColorConverter}}"
                                 Background="{ThemeResource ProgressTrackBrush}"
                                 Style="{StaticResource AppProgressBarStyle}" />

                    <!-- Percentage + model badge row -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{x:Bind ViewModel.ContextPercentageText, Mode=OneWay}"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="{ThemeResource PrimaryTextBrush}" />
                        <!-- Model badge chip -->
                        <Border Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                                Background="{x:Bind ViewModel.ContextModelBadgeColor, Mode=OneWay}"
                                CornerRadius="10" MinWidth="40">
                            <TextBlock Text="{x:Bind ViewModel.ContextModelBadge, Mode=OneWay}"
                                       FontSize="12" FontWeight="SemiBold" Padding="8,2"
                                       Foreground="White" />
                        </Border>
                    </Grid>

                    <!-- Autocompact warning -->
                    <TextBlock l:Uids.Uid="AutocompactWarning"
                               FontSize="12"
                               Foreground="{ThemeResource ProgressOrangeBrush}"
                               Visibility="{x:Bind ViewModel.ShowAutocompactWarning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <!-- No active session placeholder -->
                    <TextBlock l:Uids.Uid="NoActiveSession"
                               FontSize="12"
                               Foreground="{ThemeResource TertiaryTextBrush}"
                               Visibility="{x:Bind ViewModel.HasActiveSession, Mode=OneWay, Converter={StaticResource InvertedBoolToVisibilityConverter}}" />

                    <!-- Subagent context bars (dynamic) -->
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.SubagentContexts, Mode=OneWay}">
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="viewmodels:SubagentDisplayData">
                                <!-- Layout: [↳] [Badge] [ProgressBar] [xx%] -->
                                <Grid Margin="0,4,0,0" ColumnSpacing="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Arrow icon -->
                                    <TextBlock Grid.Column="0"
                                               Text="&#x21B3;"
                                               FontSize="15"
                                               Foreground="{ThemeResource TertiaryTextBrush}"
                                               VerticalAlignment="Center" />

                                    <!-- Model badge -->
                                    <Border Grid.Column="1"
                                            Background="{x:Bind BadgeColor}"
                                            CornerRadius="10" MinWidth="40"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind ModelBadge}"
                                                   FontSize="12" FontWeight="SemiBold" Padding="8,2"
                                                   Foreground="White" />
                                    </Border>

                                    <!-- Progress bar -->
                                    <ProgressBar Grid.Column="2"
                                                 Value="{x:Bind Percentage}" Maximum="100"
                                                 Background="{ThemeResource ProgressTrackBrush}"
                                                 Style="{StaticResource AppProgressBarStyle}"
                                                 Margin="6,0"
                                                 VerticalAlignment="Center" />

                                    <!-- Percentage text -->
                                    <TextBlock Grid.Column="3"
                                               Text="{x:Bind PercentageText}"
                                               FontSize="12"
                                               Margin="6,0,0,0"
                                               Foreground="{ThemeResource SecondaryTextBrush}"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!-- Divider after Context Window -->
                <Border Height="1" Background="{ThemeResource DividerBrush}" />

                <!-- ==================== 5-STUNDEN-FENSTER ==================== -->
                <StackPanel Spacing="8">
                    <!-- Section header with export button -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            l:Uids.Uid="SectionHeaderFiveHour"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource SectionHeaderBrush}"
                            CharacterSpacing="50"
                            VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                l:Uids.Uid="ExportButton"
                                ToolTipService.ToolTip="Export chart"
                                Background="Transparent" BorderThickness="0"
                                Padding="8" CornerRadius="6"
                                Width="32" Height="32">
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem l:Uids.Uid="ExportMenuSave"
                                                    Command="{x:Bind ViewModel.ExportChartAsPngCommand}">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE792;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem l:Uids.Uid="ExportMenuCopy"
                                                    Command="{x:Bind ViewModel.CopyChartToClipboardCommand}">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE8C8;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyout>
                            </Button.Flyout>
                            <FontIcon Glyph="&#xE898;" FontSize="16"
                                      Foreground="{ThemeResource SecondaryTextBrush}" />
                        </Button>
                    </Grid>

                    <!-- Area chart replacing ProgressBar -->
                    <Border Background="{ThemeResource ChartBackgroundBrush}"
                            CornerRadius="8" Padding="8" Height="120">
                        <canvas:CanvasControl x:Name="UsageChart"
                                              Draw="UsageChart_Draw"
                                              ClearColor="Transparent" />
                    </Border>

                    <!-- Percentage and countdown row -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Large percentage -->
                        <TextBlock
                            Text="{x:Bind ViewModel.FiveHourPercentageText, Mode=OneWay}"
                            FontSize="24"
                            FontWeight="Bold"
                            Foreground="{ThemeResource PrimaryTextBrush}" />

                        <!-- Countdown with clock icon -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="4">
                            <FontIcon Glyph="&#xE823;" FontSize="13"
                                      Foreground="{ThemeResource SecondaryTextBrush}" />
                            <TextBlock
                                Text="{x:Bind ViewModel.FiveHourCountdown, Mode=OneWay}"
                                FontSize="13"
                                Foreground="{ThemeResource SecondaryTextBrush}" />
                        </StackPanel>
                    </Grid>

                    <!-- Burn rate warning banner -->
                    <Border Background="{ThemeResource BurnRateWarningBrush}"
                            CornerRadius="6"
                            Padding="8,4"
                            Margin="0,8,0,0"
                            Visibility="{x:Bind ViewModel.IsBurnRateWarningVisible, Mode=OneWay,
                                         Converter={StaticResource BoolToVisibilityConverter}}"
                            AutomationProperties.Name="{x:Bind ViewModel.BurnRateWarningText, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <FontIcon Glyph="&#xECAD;"
                                      FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                      FontSize="12"
                                      Foreground="White" />
                            <TextBlock Text="{x:Bind ViewModel.BurnRateWarningText, Mode=OneWay}"
                                       Foreground="White"
                                       FontSize="12" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Divider -->
                <Border Height="1" Background="{ThemeResource DividerBrush}" />

                <!-- ==================== WOCHENLIMIT ==================== -->
                <StackPanel Spacing="8">
                    <!-- Section header -->
                    <TextBlock
                        l:Uids.Uid="SectionHeaderWeekly"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource SectionHeaderBrush}"
                        CharacterSpacing="50" />

                    <!-- Progress bar -->
                    <ProgressBar
                        Value="{x:Bind ViewModel.WeeklyPercentage, Mode=OneWay}"
                        Maximum="100"
                        Foreground="{x:Bind ViewModel.WeeklyUtilization, Mode=OneWay, Converter={StaticResource PercentageToColorConverter}}"
                        Background="{ThemeResource ProgressTrackBrush}"
                        Style="{StaticResource AppProgressBarStyle}" />

                    <!-- Percentage and countdown/reset row -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Large percentage -->
                        <TextBlock
                            Text="{x:Bind ViewModel.WeeklyPercentageText, Mode=OneWay}"
                            FontSize="24"
                            FontWeight="Bold"
                            Foreground="{ThemeResource PrimaryTextBrush}" />

                        <!-- Countdown and reset date -->
                        <StackPanel Grid.Column="1" HorizontalAlignment="Right"
                                    VerticalAlignment="Center" Spacing="2">
                            <!-- Countdown row -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="4">
                                <FontIcon Glyph="&#xE823;" FontSize="13"
                                          Foreground="{ThemeResource SecondaryTextBrush}" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.WeeklyCountdown, Mode=OneWay}"
                                    FontSize="13"
                                    Foreground="{ThemeResource SecondaryTextBrush}" />
                            </StackPanel>
                            <!-- Reset date -->
                            <TextBlock
                                Text="{x:Bind ViewModel.WeeklyResetDate, Mode=OneWay}"
                                FontSize="12"
                                Foreground="{ThemeResource TertiaryTextBrush}"
                                HorizontalAlignment="Right" />
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- Divider (only shown when Sonnet data present) -->
                <Border Height="1" Background="{ThemeResource DividerBrush}"
                        Visibility="{x:Bind ViewModel.HasSonnetData, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                <!-- ==================== SONNET WOCHENLIMIT ==================== -->
                <StackPanel Spacing="8"
                            Visibility="{x:Bind ViewModel.HasSonnetData, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <!-- Section header -->
                    <TextBlock
                        l:Uids.Uid="SectionHeaderSonnetWeekly"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource SectionHeaderBrush}"
                        CharacterSpacing="50" />

                    <!-- Progress bar -->
                    <ProgressBar
                        Value="{x:Bind ViewModel.SonnetPercentage, Mode=OneWay}"
                        Maximum="100"
                        Foreground="{x:Bind ViewModel.SonnetUtilization, Mode=OneWay, Converter={StaticResource PercentageToColorConverter}}"
                        Background="{ThemeResource ProgressTrackBrush}"
                        Style="{StaticResource AppProgressBarStyle}" />

                    <!-- Percentage and countdown/reset row -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Large percentage -->
                        <TextBlock
                            Text="{x:Bind ViewModel.SonnetPercentageText, Mode=OneWay}"
                            FontSize="24"
                            FontWeight="Bold"
                            Foreground="{ThemeResource PrimaryTextBrush}" />

                        <!-- Countdown and reset date -->
                        <StackPanel Grid.Column="1" HorizontalAlignment="Right"
                                    VerticalAlignment="Center" Spacing="2">
                            <!-- Countdown row -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="4">
                                <FontIcon Glyph="&#xE823;" FontSize="13"
                                          Foreground="{ThemeResource SecondaryTextBrush}" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.SonnetCountdown, Mode=OneWay}"
                                    FontSize="13"
                                    Foreground="{ThemeResource SecondaryTextBrush}" />
                            </StackPanel>
                            <!-- Reset date -->
                            <TextBlock
                                Text="{x:Bind ViewModel.SonnetResetDate, Mode=OneWay}"
                                FontSize="12"
                                Foreground="{ThemeResource TertiaryTextBrush}"
                                HorizontalAlignment="Right" />
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- Divider before STATISTIKEN -->
                <Border Height="1" Background="{ThemeResource DividerBrush}" />

                <!-- ==================== STATISTIKEN ==================== -->
                <StackPanel Spacing="8">
                    <TextBlock l:Uids.Uid="SectionHeaderStats"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{ThemeResource SectionHeaderBrush}"
                               CharacterSpacing="50" />

                    <!-- Tab Bar -->
                    <controls:Segmented
                        x:Name="StatisticsTabBar"
                        HorizontalAlignment="Stretch"
                        SelectedIndex="{x:Bind ViewModel.SelectedTabIndex, Mode=TwoWay}"
                        SelectionMode="Single">
                        <controls:Segmented.Resources>
                            <ResourceDictionary>
                                <ResourceDictionary.ThemeDictionaries>
                                    <ResourceDictionary x:Key="Default">
                                        <SolidColorBrush x:Key="SegmentedBackground" Color="#38383A" />
                                        <SolidColorBrush x:Key="SegmentedItemBackgroundSelected" Color="#3D5A9E" />
                                        <SolidColorBrush x:Key="SegmentedItemForegroundSelected" Color="#FFFFFF" />
                                        <SolidColorBrush x:Key="SegmentedPillBackground" Color="Transparent" />
                                    </ResourceDictionary>
                                    <ResourceDictionary x:Key="Light">
                                        <SolidColorBrush x:Key="SegmentedBackground" Color="#DCDCE0" />
                                        <SolidColorBrush x:Key="SegmentedItemBackgroundSelected" Color="#B8D0F5" />
                                        <SolidColorBrush x:Key="SegmentedItemForegroundSelected" Color="#1C1C1E" />
                                        <SolidColorBrush x:Key="SegmentedPillBackground" Color="Transparent" />
                                    </ResourceDictionary>
                                </ResourceDictionary.ThemeDictionaries>
                            </ResourceDictionary>
                        </controls:Segmented.Resources>
                        <controls:SegmentedItem l:Uids.Uid="TabSession" FontSize="12" />
                        <controls:SegmentedItem l:Uids.Uid="TabToday" FontSize="12" />
                        <controls:SegmentedItem l:Uids.Uid="TabWeek" FontSize="12" />
                        <controls:SegmentedItem l:Uids.Uid="TabMonth" FontSize="12" />
                    </controls:Segmented>

                    <!-- Statistics Data Table -->
                    <Grid RowSpacing="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Row 0: Modelle -->
                        <TextBlock l:Uids.Uid="StatsModels" Grid.Row="0" Grid.Column="0" FontSize="13"
                                   Foreground="{ThemeResource SecondaryTextBrush}" Margin="0,0,12,0" />
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{x:Bind ViewModel.StatisticsModels, Mode=OneWay}"
                                   FontSize="13" HorizontalAlignment="Right"
                                   Foreground="{ThemeResource PrimaryTextBrush}"
                                   TextTrimming="CharacterEllipsis" MaxLines="1"
                                   Visibility="{x:Bind local:MainView.InvertBool(ViewModel.IsAggregating), Mode=OneWay}" />
                        <Border Grid.Row="0" Grid.Column="1" Height="13" Width="60" CornerRadius="4"
                                HorizontalAlignment="Right" Background="{ThemeResource ShimmerBaseBrush}"
                                Visibility="{x:Bind ViewModel.IsAggregating, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <!-- Divider between Models and Input -->
                        <Border Grid.Row="1" Grid.ColumnSpan="2" Height="1" Margin="0,2,0,2"
                                Background="{ThemeResource DividerBrush}" />

                        <!-- Row 2: Eingabe -->
                        <TextBlock l:Uids.Uid="StatsInput" Grid.Row="2" Grid.Column="0" FontSize="13"
                                   Foreground="{ThemeResource SecondaryTextBrush}" Margin="0,0,12,0" />
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="{x:Bind ViewModel.StatisticsInput, Mode=OneWay}"
                                   FontSize="13" FontWeight="Medium" HorizontalAlignment="Right"
                                   Foreground="{ThemeResource PrimaryTextBrush}"
                                   Visibility="{x:Bind local:MainView.InvertBool(ViewModel.IsAggregating), Mode=OneWay}" />
                        <Border Grid.Row="2" Grid.Column="1" Height="13" Width="60" CornerRadius="4"
                                HorizontalAlignment="Right" Background="{ThemeResource ShimmerBaseBrush}"
                                Visibility="{x:Bind ViewModel.IsAggregating, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <!-- Row 3: Ausgabe -->
                        <TextBlock l:Uids.Uid="StatsOutput" Grid.Row="3" Grid.Column="0" FontSize="13"
                                   Foreground="{ThemeResource SecondaryTextBrush}" Margin="0,0,12,0" />
                        <TextBlock Grid.Row="3" Grid.Column="1"
                                   Text="{x:Bind ViewModel.StatisticsOutput, Mode=OneWay}"
                                   FontSize="13" FontWeight="Medium" HorizontalAlignment="Right"
                                   Foreground="{ThemeResource PrimaryTextBrush}"
                                   Visibility="{x:Bind local:MainView.InvertBool(ViewModel.IsAggregating), Mode=OneWay}" />
                        <Border Grid.Row="3" Grid.Column="1" Height="13" Width="60" CornerRadius="4"
                                HorizontalAlignment="Right" Background="{ThemeResource ShimmerBaseBrush}"
                                Visibility="{x:Bind ViewModel.IsAggregating, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <!-- Row 4: Cache-Schreiben -->
                        <TextBlock l:Uids.Uid="StatsCacheWrite" Grid.Row="4" Grid.Column="0" FontSize="13"
                                   Foreground="{ThemeResource SecondaryTextBrush}" Margin="0,0,12,0" />
                        <TextBlock Grid.Row="4" Grid.Column="1"
                                   Text="{x:Bind ViewModel.StatisticsCacheCreation, Mode=OneWay}"
                                   FontSize="13" FontWeight="Medium" HorizontalAlignment="Right"
                                   Foreground="{ThemeResource PrimaryTextBrush}"
                                   Visibility="{x:Bind local:MainView.InvertBool(ViewModel.IsAggregating), Mode=OneWay}" />
                        <Border Grid.Row="4" Grid.Column="1" Height="13" Width="60" CornerRadius="4"
                                HorizontalAlignment="Right" Background="{ThemeResource ShimmerBaseBrush}"
                                Visibility="{x:Bind ViewModel.IsAggregating, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <!-- Row 5: Cache-Lesen -->
                        <TextBlock l:Uids.Uid="StatsCacheRead" Grid.Row="5" Grid.Column="0" FontSize="13"
                                   Foreground="{ThemeResource SecondaryTextBrush}" Margin="0,0,12,0" />
                        <TextBlock Grid.Row="5" Grid.Column="1"
                                   Text="{x:Bind ViewModel.StatisticsCacheRead, Mode=OneWay}"
                                   FontSize="13" FontWeight="Medium" HorizontalAlignment="Right"
                                   Foreground="{ThemeResource PrimaryTextBrush}"
                                   Visibility="{x:Bind local:MainView.InvertBool(ViewModel.IsAggregating), Mode=OneWay}" />
                        <Border Grid.Row="5" Grid.Column="1" Height="13" Width="60" CornerRadius="4"
                                HorizontalAlignment="Right" Background="{ThemeResource ShimmerBaseBrush}"
                                Visibility="{x:Bind ViewModel.IsAggregating, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <!-- Row 6: Divider -->
                        <Border Grid.Row="6" Grid.ColumnSpan="2" Height="1" Margin="0,4,0,4"
                                Background="{ThemeResource DividerBrush}" />

                        <!-- Row 7: Gesamt (bold) -->
                        <TextBlock l:Uids.Uid="StatsTotal" Grid.Row="7" Grid.Column="0" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{ThemeResource SecondaryTextBrush}" Margin="0,0,12,0" />
                        <TextBlock Grid.Row="7" Grid.Column="1"
                                   Text="{x:Bind ViewModel.StatisticsTotal, Mode=OneWay}"
                                   FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Right"
                                   Foreground="{ThemeResource PrimaryTextBrush}"
                                   Margin="0,0,0,0"
                                   Visibility="{x:Bind local:MainView.InvertBool(ViewModel.IsAggregating), Mode=OneWay}" />
                        <Border Grid.Row="7" Grid.Column="1" Height="13" Width="60" CornerRadius="4"
                                HorizontalAlignment="Right" Background="{ThemeResource ShimmerBaseBrush}"
                                Visibility="{x:Bind ViewModel.IsAggregating, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <!-- Row 8: Kosten (bold) -->
                        <TextBlock l:Uids.Uid="StatsCost" Grid.Row="8" Grid.Column="0" FontSize="13" FontWeight="Normal"
                                   Foreground="{ThemeResource SecondaryTextBrush}" Margin="0,0,12,0" />
                        <TextBlock Grid.Row="8" Grid.Column="1"
                                   Text="{x:Bind ViewModel.StatisticsCost, Mode=OneWay}"
                                   FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Right"
                                   Foreground="{ThemeResource PrimaryTextBrush}"
                                   Visibility="{x:Bind local:MainView.InvertBool(ViewModel.IsAggregating), Mode=OneWay}" />
                        <Border Grid.Row="8" Grid.Column="1" Height="13" Width="60" CornerRadius="4"
                                HorizontalAlignment="Right" Background="{ThemeResource ShimmerBaseBrush}"
                                Visibility="{x:Bind ViewModel.IsAggregating, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                    </Grid>
                </StackPanel>

                <!-- Divider above footer -->
                <Border Height="1" Background="{ThemeResource DividerBrush}" Margin="0,4,0,0" />

                <!-- Footer toolbar -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center" Spacing="16"
                            Padding="0,8,0,4">

                    <!-- Refresh button with spinning icon -->
                    <Grid>
                        <Button l:Uids.Uid="FooterRefreshButton"
                                ToolTipService.ToolTip="Refresh"
                                Command="{x:Bind ViewModel.RefreshCommand}"
                                Background="Transparent" BorderThickness="0"
                                Padding="8" CornerRadius="6">
                            <FontIcon x:Name="RefreshIcon" Glyph="&#xE895;" FontSize="16"
                                      Foreground="{ThemeResource SecondaryTextBrush}"
                                      RenderTransformOrigin="0.5,0.5">
                                <FontIcon.RenderTransform>
                                    <RotateTransform x:Name="RefreshIconTransform" Angle="0" />
                                </FontIcon.RenderTransform>
                            </FontIcon>
                        </Button>

                        <!-- API error warning badge -->
                        <Ellipse Width="8" Height="8"
                                 Fill="{ThemeResource ProgressOrangeBrush}"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Top"
                                 Margin="0,2,2,0"
                                 Visibility="{x:Bind ViewModel.HasApiError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </Grid>

                    <!-- Settings button -->
                    <Button l:Uids.Uid="FooterSettingsButton"
                            ToolTipService.ToolTip="Settings"
                            Command="{x:Bind ViewModel.OpenSettingsCommand}"
                            Background="Transparent" BorderThickness="0"
                            Padding="8" CornerRadius="6">
                        <FontIcon Glyph="&#xE713;" FontSize="16"
                                  Foreground="{ThemeResource SecondaryTextBrush}" />
                    </Button>

                    <!-- Quit button -->
                    <Button l:Uids.Uid="FooterQuitButton"
                            ToolTipService.ToolTip="Quit"
                            Command="{x:Bind ViewModel.ExitAppCommand}"
                            Background="Transparent" BorderThickness="0"
                            Padding="8" CornerRadius="6">
                        <FontIcon Glyph="&#xE7E8;" FontSize="16"
                                  Foreground="{ThemeResource SecondaryTextBrush}" />
                    </Button>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</Page>
