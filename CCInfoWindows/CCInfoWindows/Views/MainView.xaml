<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CCInfoWindows.Views.MainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    xmlns:viewmodels="using:CCInfoWindows.ViewModels"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:local="using:CCInfoWindows.Views"
    mc:Ignorable="d">

    <Page.Resources>
        <!-- Spinner rotation storyboard -->
        <Storyboard x:Name="SpinnerStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation
                Storyboard.TargetName="RefreshIconTransform"
                Storyboard.TargetProperty="Angle"
                From="0" To="360"
                Duration="0:0:1" />
        </Storyboard>

        <!-- Session list for ComboBox (flat, sorted by activity) -->
    </Page.Resources>

    <Grid Background="{ThemeResource AppBackgroundBrush}"
          RowDefinitions="Auto,*,Auto"
          Padding="16,12,16,12">

        <!-- Hidden WebView2 for API calls via Chromium fetch() — bypasses Cloudflare -->
        <WebView2
            x:Name="ApiBridgeWebView"
            Visibility="Collapsed"
            Width="0" Height="0" />

        <!-- Row 0: Session expired InfoBar -->
        <InfoBar
            Grid.Row="0"
            Title="Session Expired"
            Message="Your session has expired. Please re-login to continue using ccInfo."
            Severity="Warning"
            IsOpen="{x:Bind ViewModel.IsSessionExpired, Mode=OneWay}"
            IsClosable="False"
            Margin="0,0,0,12">
            <InfoBar.ActionButton>
                <Button Content="Re-Login" Command="{x:Bind ViewModel.ReLoginCommand}" />
            </InfoBar.ActionButton>
        </InfoBar>

        <!-- Row 1: Dashboard content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16" Padding="0,4,0,4">

                <!-- ==================== SESSION DROPDOWN ==================== -->
                <ComboBox x:Name="SessionComboBox"
                          ItemsSource="{x:Bind ViewModel.SortedSessions, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedSession, Mode=TwoWay}"
                          HorizontalAlignment="Stretch"
                          PlaceholderText="Keine aktive Session">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="viewmodels:SessionDisplayItem">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Ellipse Width="8" Height="8"
                                         VerticalAlignment="Center"
                                         Fill="{x:Bind StatusColor}" />
                                <TextBlock Text="{x:Bind DisplayName}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Scanning indicator -->
                <TextBlock Text="Sitzungen werden gesucht..."
                           FontSize="12"
                           Foreground="{ThemeResource SecondaryTextBrush}"
                           HorizontalAlignment="Center"
                           Visibility="{x:Bind ViewModel.IsJsonlScanning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                <!-- "Aktualisiere..." indicator on startup -->
                <TextBlock
                    Text="Aktualisiere..."
                    FontSize="12"
                    Foreground="{ThemeResource SecondaryTextBrush}"
                    HorizontalAlignment="Center"
                    Visibility="{x:Bind ViewModel.IsUpdatingFromCache, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                <!-- ==================== 5-STUNDEN-FENSTER ==================== -->
                <StackPanel Spacing="8">
                    <!-- Section header -->
                    <TextBlock
                        Text="5-STUNDEN-FENSTER"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource SectionHeaderBrush}"
                        CharacterSpacing="50" />

                    <!-- Area chart replacing ProgressBar -->
                    <Border Background="{ThemeResource ChartBackgroundBrush}"
                            CornerRadius="8" Padding="8" Height="120">
                        <canvas:CanvasControl x:Name="UsageChart"
                                              Draw="UsageChart_Draw"
                                              ClearColor="Transparent" />
                    </Border>

                    <!-- Percentage and countdown row -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Large percentage -->
                        <TextBlock
                            Text="{x:Bind ViewModel.FiveHourPercentageText, Mode=OneWay}"
                            FontSize="28"
                            FontWeight="Bold"
                            Foreground="{ThemeResource PrimaryTextBrush}" />

                        <!-- Countdown with clock icon -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="4">
                            <FontIcon Glyph="&#xE823;" FontSize="13"
                                      Foreground="{ThemeResource SecondaryTextBrush}" />
                            <TextBlock
                                Text="{x:Bind ViewModel.FiveHourCountdown, Mode=OneWay}"
                                FontSize="13"
                                Foreground="{ThemeResource SecondaryTextBrush}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- Divider -->
                <Border Height="1" Background="{ThemeResource DividerBrush}" />

                <!-- ==================== WOCHENLIMIT ==================== -->
                <StackPanel Spacing="8">
                    <!-- Section header -->
                    <TextBlock
                        Text="WOCHENLIMIT"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource SectionHeaderBrush}"
                        CharacterSpacing="50" />

                    <!-- Progress bar -->
                    <ProgressBar
                        Value="{x:Bind ViewModel.WeeklyPercentage, Mode=OneWay}"
                        Maximum="100"
                        Foreground="{x:Bind ViewModel.WeeklyUtilization, Mode=OneWay, Converter={StaticResource PercentageToColorConverter}}"
                        Background="{ThemeResource ProgressTrackBrush}"
                        Height="6"
                        CornerRadius="3" />

                    <!-- Percentage and countdown/reset row -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Large percentage -->
                        <TextBlock
                            Text="{x:Bind ViewModel.WeeklyPercentageText, Mode=OneWay}"
                            FontSize="28"
                            FontWeight="Bold"
                            Foreground="{ThemeResource PrimaryTextBrush}" />

                        <!-- Countdown and reset date -->
                        <StackPanel Grid.Column="1" HorizontalAlignment="Right"
                                    VerticalAlignment="Center" Spacing="2">
                            <!-- Countdown row -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="4">
                                <FontIcon Glyph="&#xE823;" FontSize="13"
                                          Foreground="{ThemeResource SecondaryTextBrush}" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.WeeklyCountdown, Mode=OneWay}"
                                    FontSize="13"
                                    Foreground="{ThemeResource SecondaryTextBrush}" />
                            </StackPanel>
                            <!-- Reset date -->
                            <TextBlock
                                Text="{x:Bind ViewModel.WeeklyResetDate, Mode=OneWay}"
                                FontSize="12"
                                Foreground="{ThemeResource TertiaryTextBrush}"
                                HorizontalAlignment="Right" />
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- Divider (only shown when Sonnet data present) -->
                <Border Height="1" Background="{ThemeResource DividerBrush}"
                        Visibility="{x:Bind ViewModel.HasSonnetData, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                <!-- ==================== SONNET WOCHENLIMIT ==================== -->
                <StackPanel Spacing="8"
                            Visibility="{x:Bind ViewModel.HasSonnetData, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <!-- Section header -->
                    <TextBlock
                        Text="SONNET WOCHENLIMIT"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource SectionHeaderBrush}"
                        CharacterSpacing="50" />

                    <!-- Progress bar -->
                    <ProgressBar
                        Value="{x:Bind ViewModel.SonnetPercentage, Mode=OneWay}"
                        Maximum="100"
                        Foreground="{x:Bind ViewModel.SonnetUtilization, Mode=OneWay, Converter={StaticResource PercentageToColorConverter}}"
                        Background="{ThemeResource ProgressTrackBrush}"
                        Height="6"
                        CornerRadius="3" />

                    <!-- Percentage and countdown/reset row -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Large percentage -->
                        <TextBlock
                            Text="{x:Bind ViewModel.SonnetPercentageText, Mode=OneWay}"
                            FontSize="28"
                            FontWeight="Bold"
                            Foreground="{ThemeResource PrimaryTextBrush}" />

                        <!-- Countdown and reset date -->
                        <StackPanel Grid.Column="1" HorizontalAlignment="Right"
                                    VerticalAlignment="Center" Spacing="2">
                            <!-- Countdown row -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="4">
                                <FontIcon Glyph="&#xE823;" FontSize="13"
                                          Foreground="{ThemeResource SecondaryTextBrush}" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.SonnetCountdown, Mode=OneWay}"
                                    FontSize="13"
                                    Foreground="{ThemeResource SecondaryTextBrush}" />
                            </StackPanel>
                            <!-- Reset date -->
                            <TextBlock
                                Text="{x:Bind ViewModel.SonnetResetDate, Mode=OneWay}"
                                FontSize="12"
                                Foreground="{ThemeResource TertiaryTextBrush}"
                                HorizontalAlignment="Right" />
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- Divider before KONTEXTFENSTER -->
                <Border Height="1" Background="{ThemeResource DividerBrush}" />

                <!-- ==================== KONTEXTFENSTER ==================== -->
                <StackPanel Spacing="8">
                    <TextBlock Text="KONTEXTFENSTER"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{ThemeResource SectionHeaderBrush}"
                               CharacterSpacing="50" />

                    <!-- Main context progress bar -->
                    <ProgressBar Value="{x:Bind ViewModel.ContextPercentage, Mode=OneWay}"
                                 Maximum="100"
                                 Foreground="{x:Bind ViewModel.ContextUtilization, Mode=OneWay, Converter={StaticResource PercentageToColorConverter}}"
                                 Background="{ThemeResource ProgressTrackBrush}"
                                 Height="6" CornerRadius="3" />

                    <!-- Percentage + model badge row -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{x:Bind ViewModel.ContextPercentageText, Mode=OneWay}"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{ThemeResource PrimaryTextBrush}" />
                        <!-- Model badge chip -->
                        <Border Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                                Background="{x:Bind ViewModel.ContextModelBadgeColor, Mode=OneWay}"
                                CornerRadius="6" Padding="8,0" Height="20">
                            <TextBlock Text="{x:Bind ViewModel.ContextModelBadge, Mode=OneWay}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="White"
                                       VerticalAlignment="Center" />
                        </Border>
                    </Grid>

                    <!-- Autocompact warning -->
                    <TextBlock Text="&#x26A0; Autocompact bald"
                               FontSize="12"
                               Foreground="{ThemeResource ProgressOrangeBrush}"
                               Visibility="{x:Bind ViewModel.ShowAutocompactWarning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <!-- No active session placeholder -->
                    <TextBlock Text="Keine aktive Session"
                               FontSize="12"
                               Foreground="{ThemeResource TertiaryTextBrush}"
                               Visibility="{x:Bind ViewModel.HasActiveSession, Mode=OneWay, Converter={StaticResource InvertedBoolToVisibilityConverter}}" />

                    <!-- Subagent context bars (dynamic) -->
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.SubagentContexts, Mode=OneWay}">
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="viewmodels:SubagentDisplayData">
                                <StackPanel Spacing="4" Margin="12,4,0,0">
                                    <ProgressBar Value="{x:Bind Percentage}" Maximum="100"
                                                 Background="{ThemeResource ProgressTrackBrush}"
                                                 Height="4" CornerRadius="2" />
                                    <Grid>
                                        <TextBlock Text="{x:Bind PercentageText}"
                                                   FontSize="12"
                                                   Foreground="{ThemeResource SecondaryTextBrush}" />
                                        <Border HorizontalAlignment="Right"
                                                Background="{x:Bind BadgeColor}"
                                                CornerRadius="6" Padding="8,0" Height="20">
                                            <TextBlock Text="{x:Bind ModelBadge}"
                                                       FontSize="10" FontWeight="SemiBold"
                                                       Foreground="White"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!-- Divider before STATISTIKEN -->
                <Border Height="1" Background="{ThemeResource DividerBrush}" />

                <!-- ==================== STATISTIKEN ==================== -->
                <StackPanel Spacing="8">
                    <TextBlock Text="STATISTIKEN"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{ThemeResource SectionHeaderBrush}"
                               CharacterSpacing="50" />

                    <!-- Tab Bar -->
                    <controls:Segmented
                        x:Name="StatisticsTabBar"
                        HorizontalAlignment="Stretch"
                        SelectedIndex="{x:Bind ViewModel.SelectedTabIndex, Mode=TwoWay}"
                        SelectionMode="Single">
                        <controls:SegmentedItem Content="Session" />
                        <controls:SegmentedItem Content="Heute" />
                        <controls:SegmentedItem Content="Woche" />
                        <controls:SegmentedItem Content="Monat" />
                    </controls:Segmented>

                    <!-- Statistics Data Table -->
                    <Grid RowSpacing="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Row 0: Modelle -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Modelle:" FontSize="13"
                                   Foreground="{ThemeResource SecondaryTextBrush}" Margin="0,0,12,0" />
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{x:Bind ViewModel.StatisticsModels, Mode=OneWay}"
                                   FontSize="13" HorizontalAlignment="Right"
                                   Foreground="{ThemeResource PrimaryTextBrush}"
                                   TextTrimming="CharacterEllipsis" MaxLines="1"
                                   Visibility="{x:Bind local:MainView.InvertBool(ViewModel.IsAggregating), Mode=OneWay}" />
                        <Border Grid.Row="0" Grid.Column="1" Height="13" Width="60" CornerRadius="4"
                                HorizontalAlignment="Right" Background="{ThemeResource ShimmerBaseBrush}"
                                Visibility="{x:Bind ViewModel.IsAggregating, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <!-- Row 1: Eingabe -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Eingabe:" FontSize="13"
                                   Foreground="{ThemeResource SecondaryTextBrush}" Margin="0,0,12,0" />
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{x:Bind ViewModel.StatisticsInput, Mode=OneWay}"
                                   FontSize="13" FontWeight="Medium" HorizontalAlignment="Right"
                                   Foreground="{ThemeResource PrimaryTextBrush}"
                                   Visibility="{x:Bind local:MainView.InvertBool(ViewModel.IsAggregating), Mode=OneWay}" />
                        <Border Grid.Row="1" Grid.Column="1" Height="13" Width="60" CornerRadius="4"
                                HorizontalAlignment="Right" Background="{ThemeResource ShimmerBaseBrush}"
                                Visibility="{x:Bind ViewModel.IsAggregating, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <!-- Row 2: Ausgabe -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Ausgabe:" FontSize="13"
                                   Foreground="{ThemeResource SecondaryTextBrush}" Margin="0,0,12,0" />
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="{x:Bind ViewModel.StatisticsOutput, Mode=OneWay}"
                                   FontSize="13" FontWeight="Medium" HorizontalAlignment="Right"
                                   Foreground="{ThemeResource PrimaryTextBrush}"
                                   Visibility="{x:Bind local:MainView.InvertBool(ViewModel.IsAggregating), Mode=OneWay}" />
                        <Border Grid.Row="2" Grid.Column="1" Height="13" Width="60" CornerRadius="4"
                                HorizontalAlignment="Right" Background="{ThemeResource ShimmerBaseBrush}"
                                Visibility="{x:Bind ViewModel.IsAggregating, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <!-- Row 3: Cache-Schreiben -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Cache-Schreiben:" FontSize="13"
                                   Foreground="{ThemeResource SecondaryTextBrush}" Margin="0,0,12,0" />
                        <TextBlock Grid.Row="3" Grid.Column="1"
                                   Text="{x:Bind ViewModel.StatisticsCacheCreation, Mode=OneWay}"
                                   FontSize="13" FontWeight="Medium" HorizontalAlignment="Right"
                                   Foreground="{ThemeResource PrimaryTextBrush}"
                                   Visibility="{x:Bind local:MainView.InvertBool(ViewModel.IsAggregating), Mode=OneWay}" />
                        <Border Grid.Row="3" Grid.Column="1" Height="13" Width="60" CornerRadius="4"
                                HorizontalAlignment="Right" Background="{ThemeResource ShimmerBaseBrush}"
                                Visibility="{x:Bind ViewModel.IsAggregating, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <!-- Row 4: Cache-Lesen -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Cache-Lesen:" FontSize="13"
                                   Foreground="{ThemeResource SecondaryTextBrush}" Margin="0,0,12,0" />
                        <TextBlock Grid.Row="4" Grid.Column="1"
                                   Text="{x:Bind ViewModel.StatisticsCacheRead, Mode=OneWay}"
                                   FontSize="13" FontWeight="Medium" HorizontalAlignment="Right"
                                   Foreground="{ThemeResource PrimaryTextBrush}"
                                   Visibility="{x:Bind local:MainView.InvertBool(ViewModel.IsAggregating), Mode=OneWay}" />
                        <Border Grid.Row="4" Grid.Column="1" Height="13" Width="60" CornerRadius="4"
                                HorizontalAlignment="Right" Background="{ThemeResource ShimmerBaseBrush}"
                                Visibility="{x:Bind ViewModel.IsAggregating, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <!-- Row 5: Divider -->
                        <Border Grid.Row="5" Grid.ColumnSpan="2" Height="1" Margin="0,4,0,4"
                                Background="{ThemeResource DividerBrush}" />

                        <!-- Row 6: Gesamt (bold) -->
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Gesamt:" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{ThemeResource PrimaryTextBrush}" Margin="0,0,12,0" />
                        <TextBlock Grid.Row="6" Grid.Column="1"
                                   Text="{x:Bind ViewModel.StatisticsTotal, Mode=OneWay}"
                                   FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Right"
                                   Foreground="{ThemeResource PrimaryTextBrush}"
                                   Visibility="{x:Bind local:MainView.InvertBool(ViewModel.IsAggregating), Mode=OneWay}" />
                        <Border Grid.Row="6" Grid.Column="1" Height="13" Width="60" CornerRadius="4"
                                HorizontalAlignment="Right" Background="{ThemeResource ShimmerBaseBrush}"
                                Visibility="{x:Bind ViewModel.IsAggregating, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <!-- Row 7: Kosten (bold) -->
                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Kosten (API-Äqu.):" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{ThemeResource PrimaryTextBrush}" Margin="0,0,12,0" />
                        <TextBlock Grid.Row="7" Grid.Column="1"
                                   Text="{x:Bind ViewModel.StatisticsCost, Mode=OneWay}"
                                   FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Right"
                                   Foreground="{ThemeResource PrimaryTextBrush}"
                                   Visibility="{x:Bind local:MainView.InvertBool(ViewModel.IsAggregating), Mode=OneWay}" />
                        <Border Grid.Row="7" Grid.Column="1" Height="13" Width="60" CornerRadius="4"
                                HorizontalAlignment="Right" Background="{ThemeResource ShimmerBaseBrush}"
                                Visibility="{x:Bind ViewModel.IsAggregating, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <!-- Row 8: Burn Rate -->
                        <TextBlock Grid.Row="8" Grid.Column="0" Text="Burn Rate:" FontSize="13"
                                   Foreground="{ThemeResource SecondaryTextBrush}" Margin="0,0,12,0" />
                        <TextBlock Grid.Row="8" Grid.Column="1"
                                   Text="{x:Bind ViewModel.StatisticsBurnRate, Mode=OneWay}"
                                   FontSize="13" HorizontalAlignment="Right"
                                   Foreground="{ThemeResource SecondaryTextBrush}"
                                   Visibility="{x:Bind local:MainView.InvertBool(ViewModel.IsAggregating), Mode=OneWay}" />
                        <Border x:Name="BurnRateShimmer" Grid.Row="8" Grid.Column="1" Height="13" Width="60" CornerRadius="4"
                                HorizontalAlignment="Right" Background="{ThemeResource ShimmerBaseBrush}"
                                Visibility="{x:Bind ViewModel.IsAggregating, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </Grid>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Row 2: Footer toolbar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Center" Spacing="16"
                    Padding="0,8,0,4">

            <!-- Aktualisieren button with spinning icon -->
            <Grid>
                <Button Command="{x:Bind ViewModel.RefreshCommand}"
                        ToolTipService.ToolTip="Aktualisieren"
                        Background="Transparent" BorderThickness="0"
                        Padding="8" CornerRadius="6">
                    <FontIcon x:Name="RefreshIcon" Glyph="&#xE895;" FontSize="16"
                              Foreground="{ThemeResource SecondaryTextBrush}"
                              RenderTransformOrigin="0.5,0.5">
                        <FontIcon.RenderTransform>
                            <RotateTransform x:Name="RefreshIconTransform" Angle="0" />
                        </FontIcon.RenderTransform>
                    </FontIcon>
                </Button>

                <!-- API error warning badge -->
                <Ellipse Width="8" Height="8"
                         Fill="{ThemeResource ProgressOrangeBrush}"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Top"
                         Margin="0,2,2,0"
                         Visibility="{x:Bind ViewModel.HasApiError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
            </Grid>

            <!-- Einstellungen button -->
            <Button Command="{x:Bind ViewModel.OpenSettingsCommand}"
                    ToolTipService.ToolTip="Einstellungen"
                    Background="Transparent" BorderThickness="0"
                    Padding="8" CornerRadius="6">
                <FontIcon Glyph="&#xE713;" FontSize="16"
                          Foreground="{ThemeResource SecondaryTextBrush}" />
            </Button>

            <!-- Beenden button -->
            <Button Command="{x:Bind ViewModel.ExitAppCommand}"
                    ToolTipService.ToolTip="Beenden"
                    Background="Transparent" BorderThickness="0"
                    Padding="8" CornerRadius="6">
                <FontIcon Glyph="&#xE7E8;" FontSize="16"
                          Foreground="{ThemeResource SecondaryTextBrush}" />
            </Button>
        </StackPanel>
    </Grid>
</Page>
