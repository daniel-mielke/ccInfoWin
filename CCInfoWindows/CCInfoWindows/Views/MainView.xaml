<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CCInfoWindows.Views.MainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid RowDefinitions="Auto,*,Auto" Padding="16">

        <!-- Session expired InfoBar (non-invasive banner per locked decision) -->
        <InfoBar
            Grid.Row="0"
            Title="Session Expired"
            Message="Your session has expired. Please re-login to continue using ccInfo."
            Severity="Warning"
            IsOpen="{x:Bind ViewModel.IsSessionExpired, Mode=OneWay}"
            IsClosable="False"
            Margin="0,0,0,12">
            <InfoBar.ActionButton>
                <Button Content="Re-Login" Command="{x:Bind ViewModel.ReLoginCommand}" />
            </InfoBar.ActionButton>
        </InfoBar>

        <!-- Placeholder content (Phase 2 replaces this with dashboard) -->
        <StackPanel
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="8">
            <TextBlock
                Text="ccInfo Windows"
                FontSize="28"
                FontWeight="SemiBold"
                HorizontalAlignment="Center"
                Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
            <TextBlock
                Text="Logged in successfully"
                FontSize="16"
                HorizontalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <!-- Logout button -->
        <Button
            Grid.Row="2"
            Content="Logout"
            Command="{x:Bind ViewModel.LogoutCommand}"
            HorizontalAlignment="Center"
            Margin="0,12,0,0"
            Style="{ThemeResource AccentButtonStyle}" />
    </Grid>
</Page>
